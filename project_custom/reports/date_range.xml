    <record id="project_task_report" model="ir.actions.report">
        <field name="name">Project Task Report</field>
        <field name="model">project.task</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">project_custom.project_task_template</field>
        <field name="report_file">project_custom.project_task_template</field>
        <field name="binding_type">report</field>
    </record>

    <record id="project_task_report_xlsx" model="ir.actions.report">
        <field name="name">Project Task Report Xlsx</field>
        <field name="model">project.task</field>
        <field name="report_type">xlsx</field>
        <field name="report_name">project_task.project_task_xlsx</field>
        <field name="report_file">project_task.project_task_xlsx</field>
        <field name="binding_type">report</field>
    </record>


    <template id="project_task_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="task">
                <div class="page">
                    <h1>Project Task:-
                        <t t-esc="task.name"/>
                    </h1>

                    <h2>Date Assign:-
                        <t t-esc="task.date_start" />
                    </h2>
                     <h2>Date Deadline:-
                        <t t-esc="task.date_end" />
                    </h2>
                </div>
            </t>
        </t>
    </template>
</odoo>