<?xml version="1.0" encoding="UTF-8" ?>
    <odoo>
        <record id="server_print_report_pdf" model="ir.actions.server">
            <field name="name">Server Customer Report</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="binding_model_id" ref="base.model_res_partner"/>
            <field name="state">code</field>
            <field name="code">
                action = env['res.partner'].action_print_report_pdf()
            </field>
        </record>


        <record id="report_customer_action" model="ir.actions.report">
            <field name="name">Customer Report</field>
            <field name="model">res.partner</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">report_customer.report_customer_pdf</field>
            <field name="report_file">report_customer.report_customer_pdf</field>
            <field name="binding_model_id" ref="base.model_res_partner"/>
            <field name="binding_type">report</field>
        </record>

        <template id="report_customer_pdf">
            <t t-call="web.external_layout">
                <main>
                    <div class="page">

                        <t t-if="docs.company_id.logo">
                            <img t-att-src="'data:image/png;base64,%s' % (docs.company_id.logo)"
                                 style="max-height:45px;"
                                 alt="Company Logo"/>
                        </t>

                        <!-- Customer Table -->
                        <table style="width: 100%; height: 100%;" class="table-border">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Email</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="docs" t-as="detail">

                                    <tr>
                                        <td>
                                            <t t-out="detail.name"/>
                                        </td>
                                        <td>
                                            <t t-out="detail.email"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </main>
            </t>
        </template>

    </odoo>